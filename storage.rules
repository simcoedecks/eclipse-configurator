rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Proposal PDFs — writable by anyone who just created a submission
    // (no auth on retail site), readable by anyone with the URL token.
    // Max 15MB per file, PDF only.
    match /proposals/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType == 'application/pdf';
    }

    // Dealer logos — public read (rendered on dealer landing page),
    // any signed-in user can write (admin uploads logos when inviting dealers).
    // 5 MB max, image types only.
    match /dealerLogos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Submission attachments (admin uploads in detail modal)
    match /submissions/{submissionId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.size < 15 * 1024 * 1024;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
