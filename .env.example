# ─── Resend ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ─── Admin Email ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Get these from your Firebase Service Account JSON key file
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ─── Pipedrive ────────────────────────────────────────────────────────────────
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_DOMAIN=

# ─── PandaDoc ─────────────────────────────────────────────────────────────────
PANDADOC_API_KEY=
PANDADOC_TEMPLATE_ID=

# ─── Twilio (SMS proposal links) ──────────────────────────────────────────────
# Sign up at twilio.com → Account → API keys & tokens
# Buy a phone number with SMS capability (Messaging → Phone numbers → Buy)
# TWILIO_ACCOUNT_SID starts with AC...
# TWILIO_FROM_NUMBER must be in E.164 format (+15551234567)
# ADMIN_SMS_NUMBER is optional — if set, admin also gets a text when new leads submit
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ADMIN_SMS_NUMBER=

# ─── Security ─────────────────────────────────────────────────────────────────
EXPORT_SECRET=
ALLOWED_ORIGINS=
